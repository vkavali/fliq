{
  "name": "fliq",
  "version": "0.1.0",
  "private": true,
  "description": "Fliq — Indian UPI Tipping & Services Platform",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "test": "turbo test",
    "db:generate": "pnpm --filter @fliq/database generate",
    "db:migrate": "pnpm --filter @fliq/database migrate:dev",
    "db:seed": "pnpm --filter @fliq/database seed",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down"
  },
  "devDependencies": {
    "turbo": "^2.4.0",
    "typescript": "^5.7.0"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.0.0"
  }
}
