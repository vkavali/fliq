# Database
DATABASE_URL="postgresql://fliq:fliq_dev@127.0.0.1:5433/fliq?schema=public"

# Kafka (optional — backend works without it)
# KAFKA_BROKERS=localhost:9092

# JWT
JWT_SECRET=change-this-to-a-secure-random-string
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Razorpay
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# RazorpayX (Payouts)
RAZORPAYX_ACCOUNT_NUMBER=xxxxxxxxxxxxxxxx

# SMS (MSG91)
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=
MSG91_SENDER_ID=FLIQIN

# App
APP_PORT=3000
APP_ENV=development
APP_URL=http://localhost:3000  # production: https://fliq.co.in

# Encryption
ENCRYPTION_KEY=change-this-to-a-32-byte-hex-string

# WhatsApp Business API (Meta Cloud API)
# Get from: https://developers.facebook.com > Your App > WhatsApp > API Setup
WHATSAPP_ACCESS_TOKEN=EAAxxxxxxxxx
WHATSAPP_PHONE_NUMBER_ID=1234567890
WHATSAPP_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WHATSAPP_WEBHOOK_VERIFY_TOKEN=fliq_whatsapp_verify
