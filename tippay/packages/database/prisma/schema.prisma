generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ──────────────────────────────────────────────────────────────────

enum UserType {
  CUSTOMER
  PROVIDER
  ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  DEACTIVATED
}

enum KycStatus {
  PENDING
  BASIC
  FULL
}

enum ProviderCategory {
  DELIVERY
  SALON
  HOUSEHOLD
  RESTAURANT
  HOTEL
  TRANSPORT
  HEALTHCARE
  EDUCATION
  FITNESS
  OTHER
}

enum PayoutPreference {
  INSTANT
  DAILY_BATCH
  WEEKLY
}

enum WalletType {
  PROVIDER_EARNINGS
  PLATFORM_COMMISSION
  TAX_RESERVE
}

enum LedgerEntryType {
  DEBIT
  CREDIT
}

enum PaymentMethod {
  UPI
  CARD
  NET_BANKING
  WALLET
}

enum TipSource {
  QR_CODE
  PAYMENT_LINK
  IN_APP
}

enum TipStatus {
  INITIATED
  PAID
  SETTLED
  FAILED
  REFUNDED
}

enum TransactionType {
  TIP
  PAYOUT
  REFUND
  COMMISSION
  TAX_DEDUCTION
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
  REVERSED
}

enum PayoutMode {
  UPI
  IMPS
  NEFT
}

enum PayoutStatus {
  PENDING_BATCH
  INITIATED
  PROCESSED
  SETTLED
  FAILED
}

enum QrCodeType {
  STATIC
  DYNAMIC
}

enum TipJarEventType {
  WEDDING
  RESTAURANT
  SALON
  EVENT
  CUSTOM
}

enum DeferredTipStatus {
  PROMISED
  COLLECTED
  EXPIRED
  CANCELLED
}

// ─── Models ─────────────────────────────────────────────────────────────────

model User {
  id                 String     @id @default(uuid()) @db.Uuid
  type               UserType
  phone              String     @unique @db.VarChar(15)
  email              String?    @db.VarChar(255)
  name               String?    @db.VarChar(255)
  languagePreference String     @default("en") @db.VarChar(5)
  kycStatus          KycStatus  @default(PENDING)
  status             UserStatus @default(ACTIVE)
  createdAt          DateTime   @default(now()) @db.Timestamptz()
  updatedAt          DateTime   @updatedAt @db.Timestamptz()

  providerProfile    Provider?
  wallets            Wallet[]
  tipsGiven          Tip[]              @relation("CustomerTips")
  tipsReceived       Tip[]              @relation("ProviderTips")
  payouts            Payout[]
  otpCodes           OtpCode[]
  consentRecords     ConsentRecord[]
  badges             UserBadge[]
  tipStreak          TipStreak?
  ownedTipPools      TipPool[]          @relation("TipPoolOwner")
  tipPoolMemberships TipPoolMember[]
  ownedTipJars       TipJar[]           @relation("TipJarOwner")
  tipJarMemberships  TipJarMember[]     @relation("TipJarMemberProvider")
  tipJarContributions TipJarContribution[] @relation("TipJarContributor")
  deferredTipsGiven  DeferredTip[]      @relation("DeferredTipCustomer")
  deferredTipsReceived DeferredTip[]    @relation("DeferredTipProvider")

  @@map("users")
}

model Provider {
  id                         String           @id @db.Uuid
  user                       User             @relation(fields: [id], references: [id])
  upiVpa                     String?          @db.VarChar(255)
  bankAccountNumberEncrypted Bytes?
  bankIfsc                   String?          @db.VarChar(11)
  panEncrypted               Bytes?
  panVerified                Boolean          @default(false)
  bankVerified               Boolean          @default(false)
  category                   ProviderCategory @default(OTHER)
  displayName                String?          @db.VarChar(100)
  bio                        String?          @db.VarChar(500)
  avatarUrl                  String?          @db.Text
  ratingAverage              Decimal?         @db.Decimal(3, 2)
  totalTipsReceived          Int              @default(0)
  payoutPreference           PayoutPreference @default(DAILY_BATCH)
  razorpayLinkedAccountId    String?          @db.VarChar(50)
  razorpayFundAccountId      String?          @db.VarChar(50)
  qrCodeUrl                  String?
  createdAt                  DateTime         @default(now()) @db.Timestamptz()

  qrCodes      QrCode[]
  paymentLinks PaymentLink[]

  @@map("providers")
}

model OtpCode {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String?  @db.Uuid
  user      User?    @relation(fields: [userId], references: [id])
  phone     String   @db.VarChar(15)
  code      String   @db.VarChar(6)
  expiresAt DateTime @db.Timestamptz()
  verified  Boolean  @default(false)
  attempts  Int      @default(0)
  createdAt DateTime @default(now()) @db.Timestamptz()

  @@index([phone, code])
  @@map("otp_codes")
}

model Wallet {
  id           String     @id @default(uuid()) @db.Uuid
  userId       String     @db.Uuid
  user         User       @relation(fields: [userId], references: [id])
  type         WalletType
  balancePaise BigInt     @default(0)
  version      Int        @default(1)
  createdAt    DateTime   @default(now()) @db.Timestamptz()
  updatedAt    DateTime   @updatedAt @db.Timestamptz()

  ledgerEntries LedgerEntry[]

  @@unique([userId, type])
  @@map("wallets")
}

model LedgerEntry {
  id                String          @id @default(uuid()) @db.Uuid
  walletId          String          @db.Uuid
  wallet            Wallet          @relation(fields: [walletId], references: [id])
  transactionId     String          @db.Uuid
  transaction       Transaction     @relation(fields: [transactionId], references: [id])
  entryType         LedgerEntryType
  amountPaise       BigInt
  balanceAfterPaise BigInt
  description       String?
  createdAt         DateTime        @default(now()) @db.Timestamptz()

  @@index([walletId, createdAt])
  @@map("ledger_entries")
}

model Tip {
  id                   String         @id @default(uuid()) @db.Uuid
  customerId           String?        @db.Uuid
  customer             User?          @relation("CustomerTips", fields: [customerId], references: [id])
  providerId           String         @db.Uuid
  provider             User           @relation("ProviderTips", fields: [providerId], references: [id])
  amountPaise          BigInt
  commissionPaise      BigInt         @default(0)
  commissionRate       Decimal?       @db.Decimal(5, 4)
  netAmountPaise       BigInt
  gstOnCommissionPaise BigInt         @default(0)
  tdsPaise             BigInt         @default(0)
  tcsPaise             BigInt         @default(0)
  paymentMethod        PaymentMethod?
  source               TipSource
  status               TipStatus      @default(INITIATED)
  gateway              String?        @db.VarChar(20)
  gatewayOrderId       String?        @db.VarChar(100)
  gatewayPaymentId     String?        @db.VarChar(100)
  message              String?
  rating               Int?           @db.SmallInt
  createdAt            DateTime       @default(now()) @db.Timestamptz()
  updatedAt            DateTime       @updatedAt @db.Timestamptz()

  tipPoolId            String?        @db.Uuid
  tipPool              TipPool?       @relation(fields: [tipPoolId], references: [id])
  tipJarId             String?        @db.Uuid
  tipJar               TipJar?        @relation(fields: [tipJarId], references: [id])
  tipJarContribution   TipJarContribution?
  deferredTipSettlement DeferredTip?  @relation("DeferredTipSettlement")
  transactions Transaction[]

  @@index([providerId, createdAt])
  @@index([customerId, createdAt])
  @@index([gatewayPaymentId])
  @@index([tipPoolId])
  @@map("tips")
}

model Transaction {
  id                   String            @id @default(uuid()) @db.Uuid
  type                 TransactionType
  referenceId          String?           @db.Uuid
  tip                  Tip?              @relation(fields: [referenceId], references: [id])
  fromWalletId         String?           @db.Uuid
  toWalletId           String?           @db.Uuid
  amountPaise          BigInt
  status               TransactionStatus @default(PENDING)
  idempotencyKey       String?           @unique @db.VarChar(255)
  gateway              String?           @db.VarChar(20)
  gatewayTransactionId String?           @db.VarChar(100)
  metadata             Json?
  createdAt            DateTime          @default(now()) @db.Timestamptz()
  updatedAt            DateTime          @updatedAt @db.Timestamptz()

  ledgerEntries LedgerEntry[]

  @@index([referenceId])
  @@map("transactions")
}

model Payout {
  id              String       @id @default(uuid()) @db.Uuid
  providerId      String       @db.Uuid
  provider        User         @relation(fields: [providerId], references: [id])
  amountPaise     BigInt
  mode            PayoutMode   @default(IMPS)
  status          PayoutStatus @default(PENDING_BATCH)
  gateway         String?      @db.VarChar(20)
  gatewayPayoutId String?      @db.VarChar(100)
  utr             String?      @db.VarChar(50)
  failureReason   String?
  retryCount      Int          @default(0)
  batchId         String?      @db.Uuid
  createdAt       DateTime     @default(now()) @db.Timestamptz()
  settledAt       DateTime?    @db.Timestamptz()

  @@index([providerId, createdAt])
  @@map("payouts")
}

model QrCode {
  id            String     @id @default(uuid()) @db.Uuid
  providerId    String     @db.Uuid
  provider      Provider   @relation(fields: [providerId], references: [id])
  type          QrCodeType
  razorpayQrId  String?    @db.VarChar(50)
  qrImageUrl    String?
  upiUrl        String?
  locationLabel String?    @db.VarChar(255)
  scanCount     Int        @default(0)
  isActive      Boolean    @default(true)
  createdAt     DateTime   @default(now()) @db.Timestamptz()

  @@index([providerId])
  @@map("qr_codes")
}

model WebhookEvent {
  id          String    @id @default(uuid()) @db.Uuid
  eventId     String    @unique @db.VarChar(100)
  gateway     String    @db.VarChar(20)
  eventType   String    @db.VarChar(100)
  payload     Json
  processed   Boolean   @default(false)
  processedAt DateTime? @db.Timestamptz()
  createdAt   DateTime  @default(now()) @db.Timestamptz()

  @@map("webhook_events")
}

model OutboxEvent {
  id            String   @id @default(uuid()) @db.Uuid
  aggregateType String   @db.VarChar(50)
  aggregateId   String   @db.Uuid
  eventType     String   @db.VarChar(100)
  payload       Json
  published     Boolean  @default(false)
  createdAt     DateTime @default(now()) @db.Timestamptz()

  @@index([published, createdAt])
  @@map("outbox_events")
}

model PaymentLink {
  id                 String   @id @default(uuid()) @db.Uuid
  providerId         String   @db.Uuid
  provider           Provider @relation(fields: [providerId], references: [id])
  shortCode          String   @unique @db.VarChar(8)
  role               String?  @db.VarChar(100)
  workplace          String?  @db.VarChar(200)
  description        String?  @db.VarChar(255)
  suggestedAmountPaise Int?
  allowCustomAmount  Boolean  @default(true)
  clickCount         Int      @default(0)
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now()) @db.Timestamptz()
  updatedAt          DateTime @updatedAt @db.Timestamptz()

  @@index([providerId])
  @@map("payment_links")
}

model ConsentRecord {
  id            String    @id @default(uuid()) @db.Uuid
  userId        String    @db.Uuid
  user          User      @relation(fields: [userId], references: [id])
  purpose       String    @db.VarChar(50)
  granted       Boolean   @default(true)
  grantedAt     DateTime  @default(now()) @db.Timestamptz()
  withdrawnAt   DateTime? @db.Timestamptz()
  policyVersion String    @db.VarChar(20)
  channel       String    @db.VarChar(20)

  @@map("consent_records")
}

// ─── Tip Pools ──────────────────────────────────────────────────────────────

model TipPool {
  id          String          @id @default(uuid()) @db.Uuid
  name        String          @db.VarChar(100)
  ownerId     String          @db.Uuid
  owner       User            @relation("TipPoolOwner", fields: [ownerId], references: [id])
  description String?         @db.VarChar(500)
  splitMethod String          @default("EQUAL") @db.VarChar(20) // EQUAL, PERCENTAGE, ROLE_BASED
  isActive    Boolean         @default(true)
  members     TipPoolMember[]
  tips        Tip[]
  createdAt   DateTime        @default(now()) @db.Timestamptz()
  updatedAt   DateTime        @updatedAt @db.Timestamptz()

  @@index([ownerId])
  @@map("tip_pools")
}

// ─── Tip Jars ────────────────────────────────────────────────────────────────

model TipJar {
  id             String          @id @default(uuid()) @db.Uuid
  name           String          @db.VarChar(100)
  description    String?         @db.VarChar(500)
  createdById    String          @db.Uuid
  createdBy      User            @relation("TipJarOwner", fields: [createdById], references: [id])
  eventType      TipJarEventType @default(CUSTOM)
  shortCode      String          @unique @db.VarChar(8)
  isActive       Boolean         @default(true)
  expiresAt      DateTime?       @db.Timestamptz()
  totalCollected BigInt          @default(0)
  targetAmount   BigInt?
  createdAt      DateTime        @default(now()) @db.Timestamptz()
  updatedAt      DateTime        @updatedAt @db.Timestamptz()

  members       TipJarMember[]
  contributions TipJarContribution[]
  tips          Tip[]

  @@index([createdById])
  @@map("tip_jars")
}

model TipJarMember {
  id              String   @id @default(uuid()) @db.Uuid
  tipJarId        String   @db.Uuid
  tipJar          TipJar   @relation(fields: [tipJarId], references: [id])
  providerId      String   @db.Uuid
  provider        User     @relation("TipJarMemberProvider", fields: [providerId], references: [id])
  splitPercentage Float    @default(0)
  roleLabel       String?  @db.VarChar(100)
  isActive        Boolean  @default(true)
  joinedAt        DateTime @default(now()) @db.Timestamptz()

  @@unique([tipJarId, providerId])
  @@index([providerId])
  @@map("tip_jar_members")
}

model TipJarContribution {
  id          String   @id @default(uuid()) @db.Uuid
  tipJarId    String   @db.Uuid
  tipJar      TipJar   @relation(fields: [tipJarId], references: [id])
  tipId       String   @unique @db.Uuid
  tip         Tip      @relation(fields: [tipId], references: [id])
  customerId  String?  @db.Uuid
  customer    User?    @relation("TipJarContributor", fields: [customerId], references: [id])
  amountPaise BigInt
  message     String?  @db.VarChar(500)
  createdAt   DateTime @default(now()) @db.Timestamptz()

  @@index([tipJarId, createdAt])
  @@map("tip_jar_contributions")
}

// ─── Deferred Tips ────────────────────────────────────────────────────────────

model DeferredTip {
  id          String            @id @default(uuid()) @db.Uuid
  customerId  String            @db.Uuid
  customer    User              @relation("DeferredTipCustomer", fields: [customerId], references: [id])
  providerId  String            @db.Uuid
  provider    User              @relation("DeferredTipProvider", fields: [providerId], references: [id])
  amountPaise BigInt
  message     String?           @db.VarChar(500)
  rating      Int?              @db.SmallInt
  promisedAt  DateTime          @default(now()) @db.Timestamptz()
  dueAt       DateTime          @db.Timestamptz()
  status      DeferredTipStatus @default(PROMISED)
  mandateId   String?           @db.VarChar(100)
  tipId       String?           @unique @db.Uuid
  tip         Tip?              @relation("DeferredTipSettlement", fields: [tipId], references: [id])
  createdAt   DateTime          @default(now()) @db.Timestamptz()
  updatedAt   DateTime          @updatedAt @db.Timestamptz()

  @@index([customerId, status])
  @@index([providerId, status])
  @@index([dueAt, status])
  @@map("deferred_tips")
}

model TipPoolMember {
  id              String   @id @default(uuid()) @db.Uuid
  poolId          String   @db.Uuid
  pool            TipPool  @relation(fields: [poolId], references: [id])
  userId          String   @db.Uuid
  user            User     @relation(fields: [userId], references: [id])
  role            String?  @db.VarChar(50) // "waiter", "chef", "host", etc.
  splitPercentage Float?   // Used when splitMethod is PERCENTAGE
  isActive        Boolean  @default(true)
  joinedAt        DateTime @default(now()) @db.Timestamptz()

  @@unique([poolId, userId])
  @@index([userId])
  @@map("tip_pool_members")
}

// ─── Gamification ────────────────────────────────────────────────────────────

model Badge {
  id          String      @id @default(uuid()) @db.Uuid
  code        String      @unique @db.VarChar(50)
  name        String      @db.VarChar(100)
  description String      @db.VarChar(255)
  iconUrl     String?
  category    String      @db.VarChar(20) // TIPPER, PROVIDER, STREAK, MILESTONE
  threshold   Int         // e.g., 7 for "streak_7", 50000 for "big_tipper" (paise)
  createdAt   DateTime    @default(now()) @db.Timestamptz()

  userBadges  UserBadge[]

  @@map("badges")
}

model UserBadge {
  id       String   @id @default(uuid()) @db.Uuid
  userId   String   @db.Uuid
  user     User     @relation(fields: [userId], references: [id])
  badgeId  String   @db.Uuid
  badge    Badge    @relation(fields: [badgeId], references: [id])
  earnedAt DateTime @default(now()) @db.Timestamptz()

  @@unique([userId, badgeId])
  @@index([userId])
  @@map("user_badges")
}

model TipStreak {
  id            String    @id @default(uuid()) @db.Uuid
  userId        String    @unique @db.Uuid
  user          User      @relation(fields: [userId], references: [id])
  currentStreak Int       @default(0)
  longestStreak Int       @default(0)
  lastTipDate   DateTime? @db.Timestamptz()
  updatedAt     DateTime  @updatedAt @db.Timestamptz()

  @@map("tip_streaks")
}
